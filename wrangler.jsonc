{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "itsfree-dev",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-07-19",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/", "/es/*", "/language/*"],
    "not_found_handling": "404-page",
    "html_handling": "drop-trailing-slash"
  }
}
