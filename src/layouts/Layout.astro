---
import "../styles/global.css"
import { ClientRouter } from "astro:transitions"

export interface Props {
  title: string
  description?: string
  canonical?: string
  alternate?: string
  locale?: "en" | "es"
  image?: string
  type?: "website" | "article"
  noindex?: boolean
}

const {
  title,
  description = "A curated bilingual directory of free tools and services for developers.",
  canonical,
  alternate,
  locale = "en",
  image,
  type = "website",
  noindex = false,
} = Astro.props
const siteUrl = Astro.site ?? new URL("https://itsfree.dev")
const requestedCanonical = canonical ?? Astro.url.pathname
const canonicalPath = requestedCanonical === "/" ? "/" : requestedCanonical.replace(/\/+$/, "")
const canonicalUrl = canonicalPath === "/" ? siteUrl.origin : new URL(canonicalPath, siteUrl).href
const alternatePath = alternate === "/" ? "/" : alternate?.replace(/\/+$/, "")
const alternateUrl = alternatePath === "/" ? siteUrl.origin : alternatePath ? new URL(alternatePath, siteUrl).href : undefined
const englishUrl = locale === "en" ? canonicalUrl : alternateUrl
const spanishUrl = locale === "es" ? canonicalUrl : alternateUrl
const imagePath = image ?? (locale === "es" ? "/og-es.jpg" : "/og-en.jpg")
const imageUrl = new URL(imagePath, siteUrl)
const imageAlt =
  locale === "es"
    ? "it's free* — catálogo de herramientas gratis para developers"
    : "it's free* — curated free tools for developers"
---

<!doctype html>
<html lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="midu.dev" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="googlebot" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <link rel="canonical" href={canonicalUrl} />
    {englishUrl && <link rel="alternate" hreflang="en" href={englishUrl} />}
    {spanishUrl && <link rel="alternate" hreflang="es" href={spanishUrl} />}
    {englishUrl && <link rel="alternate" hreflang="x-default" href={englishUrl} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#090a0c" />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="it's free*" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
    <meta property="og:locale:alternate" content={locale === "es" ? "en_US" : "es_ES"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script is:inline>
      try {
        const savedTheme = localStorage.getItem("itsfree-theme")
        if (savedTheme === "light" || savedTheme === "dark") {
          document.documentElement.dataset.theme = savedTheme
        }
      } catch {}
    </script>
    <ClientRouter fallback="animate" />
  </head>
  <body>
    <slot />
    <script>
      let categoryNavigationPending = false

      const syncThemeToggle = () => {
        const toggle = document.querySelector<HTMLElement>("#theme-toggle")
        if (!toggle) return
        toggle.setAttribute("aria-label", document.documentElement.dataset.theme === "light" ? "Use dark theme" : "Use light theme")
      }

      document.addEventListener("click", (event) => {
        const target = event.target
        if (!(target instanceof Element)) return

        if (target.closest("[data-category-navigation]") && event instanceof MouseEvent && event.button === 0 && !event.metaKey && !event.ctrlKey && !event.shiftKey && !event.altKey) {
          categoryNavigationPending = true
          return
        }

        if (!target.closest("#theme-toggle")) return

        const root = document.documentElement
        const nextTheme = root.dataset.theme === "light" ? "dark" : "light"
        root.dataset.theme = nextTheme
        try { localStorage.setItem("itsfree-theme", nextTheme) } catch {}
        syncThemeToggle()
      })

      document.addEventListener("astro:after-swap", () => {
        if (!categoryNavigationPending) return

        const directory = document.querySelector<HTMLElement>("#directory")
        if (directory) {
          const root = document.documentElement
          const previousScrollBehavior = root.style.scrollBehavior
          const headerHeight = document.querySelector<HTMLElement>(".topbar")?.offsetHeight ?? 0
          root.style.scrollBehavior = "auto"
          window.scrollTo(0, window.scrollY + directory.getBoundingClientRect().top - headerHeight)
          root.style.scrollBehavior = previousScrollBehavior
        }

        categoryNavigationPending = false
      })

      document.addEventListener("astro:page-load", syncThemeToggle)
      syncThemeToggle()
    </script>
  </body>
</html>
