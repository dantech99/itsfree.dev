---
import "../styles/global.css"

export interface Props {
  title: string
  description?: string
  canonical?: string
  image?: string
  type?: "website" | "article"
  noindex?: boolean
}

const {
  title,
  description = "A curated bilingual directory of free tools and services for developers.",
  canonical,
  image = "/favicon.png",
  type = "website",
  noindex = false,
} = Astro.props
const siteUrl = Astro.site ?? new URL("https://itsfree.dev")
const requestedCanonical = canonical ?? Astro.url.pathname
const canonicalPath = requestedCanonical === "/" ? "/" : requestedCanonical.replace(/\/+$/, "")
const canonicalUrl = new URL(canonicalPath, siteUrl)
const imageUrl = new URL(image, siteUrl)
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="midu.dev" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="googlebot" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#090a0c" />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="it's free*" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="530" />
    <meta property="og:image:alt" content="it's free* — curated free tools for developers" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="it's free* — curated free tools for developers" />
    <script is:inline>
      try {
        const savedTheme = localStorage.getItem("itsfree-theme")
        const savedLocale = localStorage.getItem("itsfree-locale")
        if (savedTheme === "light" || savedTheme === "dark") {
          document.documentElement.dataset.theme = savedTheme
        }
        if (savedLocale === "es" || savedLocale === "en") {
          document.documentElement.lang = savedLocale
        }
      } catch {}
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
