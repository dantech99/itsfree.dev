---
export interface Props {
  name: string;
  description: string;
  url: string;
  tags: string[];
}

const { name, description, url, tags } = Astro.props;
---

<div class="resource-card">
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-lg font-semibold text-black">{name}</h3>
    <a 
      href={url} 
      target="_blank" 
      rel="noopener noreferrer"
      class="text-gray-400 hover:text-black transition-colors duration-200"
      aria-label={`Visitar ${name}`}
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
      </svg>
    </a>
  </div>
  
  <p class="text-gray-600 mb-4 leading-relaxed">{description}</p>
  
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded-md font-medium">
        {tag}
      </span>
    ))}
  </div>
</div>
