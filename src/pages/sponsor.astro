---
import Layout from "../layouts/Layout.astro"
import LogoMark from "../components/LogoMark.astro"

const email = "miduga@gmail.com"
const subject = "Sponsorship request — it's free*"
const body = `Hi midu.dev team,

I'd like to sponsor it's free*.

Product:
Website:
Preferred category:
Preferred start date:

Thanks!`
const contactUrl = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`
const sponsorStructuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "it's free* directory sponsorship",
  description: "Exclusive sponsor placement in the it's free* developer tools directory for 30 consecutive days.",
  provider: { "@type": "Organization", name: "midu.dev", url: "https://midu.dev" },
  areaServed: "Worldwide",
  offers: {
    "@type": "Offer",
    price: "1500",
    priceCurrency: "EUR",
    url: "https://itsfree.dev/sponsor",
    availability: "https://schema.org/LimitedAvailability",
  },
}
---

<Layout
  title="Sponsor it's free* — Reach developers"
  description="Sponsor it's free* and put your developer product in front of an audience actively looking for useful tools."
>
  <div class="site-shell sponsor-page">
    <header class="topbar">
      <a class="brand" href="/" aria-label="it's free home">
        <LogoMark />
        <span class="brand-name">it's free<span>*</span></span>
      </a>

      <nav class="topbar-nav" aria-label="Primary navigation">
        <a href="/" data-i18n data-en="Directory" data-es="Directorio">Directory</a>
        <a class="active-link" href="/sponsor" data-i18n data-en="Sponsor" data-es="Patrocinar">Sponsor</a>
      </nav>

      <div class="topbar-actions">
        <button class="icon-button" id="theme-toggle" type="button" aria-label="Use light theme">
          <svg class="sun-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path></svg>
          <svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.4 15.5A8.4 8.4 0 0 1 8.5 3.6 8.4 8.4 0 1 0 20.4 15.5Z"></path></svg>
        </button>
        <button class="language-button" id="language-toggle" type="button" aria-label="Cambiar a español">ES</button>
      </div>
    </header>

    <main>
      <section class="sponsor-hero">
        <div class="sponsor-hero-copy">
          <p class="eyebrow"><span class="status-dot"></span><span data-i18n data-en="One sponsor slot per cycle" data-es="Una plaza de sponsor por ciclo">One sponsor slot per cycle</span></p>
          <h1><span data-i18n data-en="Your product." data-es="Tu producto.">Your product.</span><span class="hero-accent" data-i18n data-en="Their next tool." data-es="Su próxima herramienta.">Their next tool.</span></h1>
          <p data-i18n data-en="Reach developers at the exact moment they are searching for infrastructure, APIs and tools to build their next project." data-es="Llega a developers justo cuando están buscando infraestructura, APIs y herramientas para construir su próximo proyecto.">
            Reach developers at the exact moment they are searching for infrastructure, APIs and tools to build their next project.
          </p>
          <a class="primary-cta" href={contactUrl}>
            <span data-i18n data-en="Request the sponsor slot" data-es="Solicitar el patrocinio">Request the sponsor slot</span>
            <span>↗</span>
          </a>
        </div>

        <div class="sponsor-offer" aria-label="Sponsorship price">
          <div class="offer-topline"><span>SPONSOR_01</span><span data-i18n data-en="Launch price" data-es="Precio de lanzamiento">Launch price</span></div>
          <div class="offer-price"><span>€</span><strong>1,500</strong></div>
          <p class="offer-period" data-i18n data-en="for 30 days · VAT not included" data-es="durante 30 días · IVA no incluido">for 30 days · VAT not included</p>
          <ul>
            <li><span>✦</span><span data-i18n data-en="Prominent placement above the directory" data-es="Posición destacada sobre el directorio">Prominent placement above the directory</span></li>
            <li><span>✦</span><span data-i18n data-en="Logo, message and direct link" data-es="Logo, mensaje y enlace directo">Logo, message and direct link</span></li>
            <li><span>✦</span><span data-i18n data-en="Visible in English and Spanish" data-es="Visible en inglés y español">Visible in English and Spanish</span></li>
            <li><span>✦</span><span data-i18n data-en="Exclusive slot during the campaign" data-es="Espacio exclusivo durante la campaña">Exclusive slot during the campaign</span></li>
          </ul>
          <a href={contactUrl}><span data-i18n data-en="Contact midu.dev" data-es="Contactar con midu.dev">Contact midu.dev</span><span>→</span></a>
          <small><span data-i18n data-en="Write to" data-es="Escribe a">Write to</span> {email}</small>
        </div>
      </section>

      <section class="sponsor-values" aria-labelledby="why-sponsor-title">
        <div class="sponsor-section-heading">
          <p class="section-kicker">// WHY_SPONSOR</p>
          <h2 id="why-sponsor-title" data-i18n data-en="Attention with intent." data-es="Atención con intención.">Attention with intent.</h2>
          <p data-i18n data-en="Not another generic banner. Your product appears inside a focused experience built for tool discovery." data-es="No es otro banner genérico. Tu producto aparece dentro de una experiencia centrada en descubrir herramientas.">Not another generic banner. Your product appears inside a focused experience built for tool discovery.</p>
        </div>
        <div class="value-grid">
          <article><span>01</span><h3 data-i18n data-en="Relevant context" data-es="Contexto relevante">Relevant context</h3><p data-i18n data-en="Your brand reaches people who are actively comparing developer products." data-es="Tu marca llega a personas que están comparando productos para developers.">Your brand reaches people who are actively comparing developer products.</p></article>
          <article><span>02</span><h3 data-i18n data-en="Native placement" data-es="Integración nativa">Native placement</h3><p data-i18n data-en="The sponsor module follows the visual language of the site without pretending to be editorial content." data-es="El módulo respeta el diseño de la web sin hacerse pasar por contenido editorial.">The sponsor module follows the visual language of the site without pretending to be editorial content.</p></article>
          <article><span>03</span><h3 data-i18n data-en="Bilingual reach" data-es="Alcance bilingüe">Bilingual reach</h3><p data-i18n data-en="We adapt your message for both English- and Spanish-speaking developers." data-es="Adaptamos tu mensaje para developers que hablan inglés y español.">We adapt your message for both English- and Spanish-speaking developers.</p></article>
        </div>
      </section>

      <section class="sponsor-preview" aria-labelledby="preview-title">
        <div class="preview-copy">
          <p class="section-kicker">// YOUR_PLACEMENT</p>
          <h2 id="preview-title" data-i18n data-en="Clearly sponsored. Beautifully integrated." data-es="Claramente patrocinado. Bien integrado.">Clearly sponsored. Beautifully integrated.</h2>
          <p data-i18n data-en="Trust matters. The placement is always labeled as sponsored and kept separate from organic recommendations." data-es="La confianza importa. El espacio siempre estará marcado como patrocinado y separado de las recomendaciones orgánicas.">Trust matters. The placement is always labeled as sponsored and kept separate from organic recommendations.</p>
        </div>
        <div class="preview-card">
          <div class="preview-label"><span data-i18n data-en="Sponsored" data-es="Patrocinado">Sponsored</span><span>AD*</span></div>
          <div class="preview-logo">YOU</div>
          <div><h3 data-i18n data-en="Your product belongs here" data-es="Tu producto puede estar aquí">Your product belongs here</h3><p data-i18n data-en="A short, useful message explaining why developers should care." data-es="Un mensaje breve y útil que explique por qué debería interesar a developers.">A short, useful message explaining why developers should care.</p></div>
          <span class="preview-arrow">↗</span>
        </div>
      </section>

      <section class="sponsor-process" aria-labelledby="process-title">
        <div class="sponsor-section-heading">
          <p class="section-kicker">// HOW_IT_WORKS</p>
          <h2 id="process-title" data-i18n data-en="From hello to live." data-es="Del hola a publicado.">From hello to live.</h2>
        </div>
        <ol>
          <li><span>01</span><div><h3 data-i18n data-en="Send the product" data-es="Envía el producto">Send the product</h3><p data-i18n data-en="Email the URL, category and preferred campaign date." data-es="Envía por email la URL, categoría y fecha preferida.">Email the URL, category and preferred campaign date.</p></div></li>
          <li><span>02</span><div><h3 data-i18n data-en="Editorial review" data-es="Revisión editorial">Editorial review</h3><p data-i18n data-en="We confirm that the product is relevant and prepare the bilingual copy." data-es="Confirmamos que el producto encaja y preparamos el texto bilingüe.">We confirm that the product is relevant and prepare the bilingual copy.</p></div></li>
          <li><span>03</span><div><h3 data-i18n data-en="Payment and preview" data-es="Pago y preview">Payment and preview</h3><p data-i18n data-en="You receive payment details and approve the final placement before launch." data-es="Recibes los datos de pago y apruebas el resultado antes de publicar.">You receive payment details and approve the final placement before launch.</p></div></li>
          <li><span>04</span><div><h3 data-i18n data-en="Go live" data-es="Publicación">Go live</h3><p data-i18n data-en="The exclusive sponsor placement runs for 30 consecutive days." data-es="El espacio exclusivo de sponsor se publica durante 30 días seguidos.">The exclusive sponsor placement runs for 30 consecutive days.</p></div></li>
        </ol>
      </section>

      <section class="sponsor-eligibility">
        <p class="section-kicker">// GOOD_FIT</p>
        <div><h2 data-i18n data-en="Useful products only." data-es="Solo productos útiles.">Useful products only.</h2><p data-i18n data-en="We accept developer tools, SaaS, infrastructure, APIs, education and products relevant to builders. We do not accept gambling, deceptive products or campaigns that compromise user trust." data-es="Aceptamos herramientas para developers, SaaS, infraestructura, APIs, educación y productos relevantes para makers. No aceptamos apuestas, productos engañosos ni campañas que comprometan la confianza del usuario.">We accept developer tools, SaaS, infrastructure, APIs, education and products relevant to builders. We do not accept gambling, deceptive products or campaigns that compromise user trust.</p></div>
      </section>

      <section class="sponsor-final-cta">
        <span class="sponsor-final-mark">AD*</span>
        <h2 data-i18n data-en="Ready to be discovered?" data-es="¿Listo para que te descubran?">Ready to be discovered?</h2>
        <p><span data-i18n data-en="Tell us what you are building at" data-es="Cuéntanos qué estás construyendo en">Tell us what you are building at</span> <a href={contactUrl}>{email}</a></p>
        <a class="primary-cta" href={contactUrl}><span data-i18n data-en="Start the conversation" data-es="Empezar la conversación">Start the conversation</span><span>↗</span></a>
      </section>
    </main>

    <footer class="footer">
      <a class="brand footer-brand" href="/"><LogoMark /><span class="brand-name">it's free<span>*</span></span></a>
      <div class="footer-signature"><p><span data-i18n data-en="A project by" data-es="Un proyecto de">A project by</span> <a href="https://midu.dev" target="_blank" rel="noreferrer">midu.dev ↗</a></p><p data-i18n data-en="Made for developers who read the pricing page first." data-es="Hecho para developers que leen primero la página de precios.">Made for developers who read the pricing page first.</p></div>
      <nav class="social-links" aria-label="midu.dev social networks"><a href="https://twitter.com/midudev" target="_blank" rel="noreferrer">X <span>↗</span></a><a href="https://youtube.com/@midudev" target="_blank" rel="noreferrer">YouTube <span>↗</span></a><a href="https://twitch.tv/midudev" target="_blank" rel="noreferrer">Twitch <span>↗</span></a></nav>
    </footer>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(sponsorStructuredData)} />

  <script>
    const root = document.documentElement
    const languageToggle = document.querySelector<HTMLButtonElement>("#language-toggle")!
    const themeToggle = document.querySelector<HTMLButtonElement>("#theme-toggle")!
    const getLocale = () => root.lang === "es" ? "es" : "en"

    function applyLocale(locale: "en" | "es") {
      root.lang = locale
      document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((element) => {
        const translation = locale === "es" ? element.dataset.es : element.dataset.en
        if (translation) element.textContent = translation
      })
      languageToggle.textContent = locale === "es" ? "EN" : "ES"
      languageToggle.setAttribute("aria-label", locale === "es" ? "Switch to English" : "Cambiar a español")
      try { localStorage.setItem("itsfree-locale", locale) } catch {}
    }

    languageToggle.addEventListener("click", () => applyLocale(getLocale() === "en" ? "es" : "en"))
    themeToggle.addEventListener("click", () => {
      const nextTheme = root.dataset.theme === "light" ? "dark" : "light"
      root.dataset.theme = nextTheme
      themeToggle.setAttribute("aria-label", nextTheme === "dark" ? "Use light theme" : "Use dark theme")
      try { localStorage.setItem("itsfree-theme", nextTheme) } catch {}
    })
    applyLocale(getLocale())
  </script>
</Layout>
