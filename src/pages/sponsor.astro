---
import Layout from "../layouts/Layout.astro"
import LogoMark from "../components/LogoMark.astro"

interface Props {
  locale?: "en" | "es"
}

const { locale = "en" } = Astro.props as Props
const t = <T,>(copy: { en: T; es: T }) => copy[locale]
const localePrefix = locale === "es" ? "/es" : ""
const pagePath = `${localePrefix}/sponsor`
const alternateUrl = locale === "es" ? "/sponsor" : "/es/sponsor"

const email = "miduga@gmail.com"
const subject = "Sponsorship request — it's free*"
const body = `Hi midu.dev team,

I'd like to sponsor it's free*.

Product:
Website:
Preferred category:
Preferred start date:

Thanks!`
const contactUrl = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`
const sponsorStructuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: t({ en: "it's free* directory sponsorship", es: "Patrocinio del directorio it's free*" }),
  description: t({ en: "Exclusive sponsor placement in the it's free* developer tools directory for 30 consecutive days.", es: "Espacio de patrocinio exclusivo durante 30 días consecutivos en el directorio de herramientas para developers it's free*." }),
  inLanguage: locale,
  provider: { "@type": "Organization", name: "midu.dev", url: "https://midu.dev" },
  areaServed: "Worldwide",
  offers: {
    "@type": "Offer",
    price: "1500",
    priceCurrency: "EUR",
    url: `https://itsfree.dev${pagePath}`,
    availability: "https://schema.org/LimitedAvailability",
  },
}
---

<Layout
  title={t({ en: "Sponsor it's free* — Reach developers", es: "Patrocina it's free* — Llega a developers" })}
  description={t({ en: "Sponsor it's free* and put your developer product in front of an audience actively looking for useful tools.", es: "Patrocina it's free* y muestra tu producto a una audiencia que busca activamente herramientas útiles." })}
  locale={locale}
  canonical={pagePath}
  alternate={alternateUrl}
>
  <div class="site-shell sponsor-page">
    <header class="topbar">
      <a class="brand" href={localePrefix || "/"} aria-label="it's free home">
        <LogoMark />
        <span class="brand-name">it's free<span>*</span></span>
      </a>

      <nav class="topbar-nav" aria-label="Primary navigation">
        <a href={localePrefix || "/"}>{t({ en: "Directory", es: "Directorio" })}</a>
        <a class="active-link" href={pagePath}>{t({ en: "Sponsor", es: "Patrocinar" })}</a>
      </nav>

      <div class="topbar-actions">
        <button class="icon-button" id="theme-toggle" type="button" aria-label="Use light theme">
          <svg class="sun-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path></svg>
          <svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.4 15.5A8.4 8.4 0 0 1 8.5 3.6 8.4 8.4 0 1 0 20.4 15.5Z"></path></svg>
        </button>
        <a class="language-button" href={alternateUrl} lang={locale === "es" ? "en" : "es"} hreflang={locale === "es" ? "en" : "es"} aria-label={t({ en: "Cambiar a español", es: "Switch to English" })}>{locale === "es" ? "EN" : "ES"}</a>
      </div>
    </header>

    <main>
      <section class="sponsor-hero">
        <div class="sponsor-hero-copy">
          <p class="eyebrow"><span class="status-dot"></span><span>{t({ en: "One sponsor slot per cycle", es: "Una plaza de sponsor por ciclo" })}</span></p>
          <h1><span>{t({ en: "Your product.", es: "Tu producto." })}</span><span class="hero-accent">{t({ en: "Their next tool.", es: "Su próxima herramienta." })}</span></h1>
          <p>{t({ en: "Reach developers at the exact moment they are searching for infrastructure, APIs and tools to build their next project.", es: "Llega a developers justo cuando están buscando infraestructura, APIs y herramientas para construir su próximo proyecto." })}</p>
          <a class="primary-cta" href={contactUrl}>
            <span>{t({ en: "Request the sponsor slot", es: "Solicitar el patrocinio" })}</span>
            <span>↗</span>
          </a>
        </div>

        <div class="sponsor-offer" aria-label="Sponsorship price">
          <div class="offer-topline"><span>SPONSOR_01</span><span>{t({ en: "Launch price", es: "Precio de lanzamiento" })}</span></div>
          <div class="offer-price"><span>€</span><strong>1,500</strong></div>
          <p class="offer-period">{t({ en: "for 30 days · VAT not included", es: "durante 30 días · IVA no incluido" })}</p>
          <ul>
            <li><span>✦</span><span>{t({ en: "Prominent placement above the directory", es: "Posición destacada sobre el directorio" })}</span></li>
            <li><span>✦</span><span>{t({ en: "Logo, message and direct link", es: "Logo, mensaje y enlace directo" })}</span></li>
            <li><span>✦</span><span>{t({ en: "Visible in English and Spanish", es: "Visible en inglés y español" })}</span></li>
            <li><span>✦</span><span>{t({ en: "Exclusive slot during the campaign", es: "Espacio exclusivo durante la campaña" })}</span></li>
          </ul>
          <a href={contactUrl}><span>{t({ en: "Contact midu.dev", es: "Contactar con midu.dev" })}</span><span>→</span></a>
          <small><span>{t({ en: "Write to", es: "Escribe a" })}</span> {email}</small>
        </div>
      </section>

      <section class="sponsor-values" aria-labelledby="why-sponsor-title">
        <div class="sponsor-section-heading">
          <p class="section-kicker">// WHY_SPONSOR</p>
          <h2 id="why-sponsor-title">{t({ en: "Attention with intent.", es: "Atención con intención." })}</h2>
          <p>{t({ en: "Not another generic banner. Your product appears inside a focused experience built for tool discovery.", es: "No es otro banner genérico. Tu producto aparece dentro de una experiencia centrada en descubrir herramientas." })}</p>
        </div>
        <div class="value-grid">
          <article><span>01</span><h3>{t({ en: "Relevant context", es: "Contexto relevante" })}</h3><p>{t({ en: "Your brand reaches people who are actively comparing developer products.", es: "Tu marca llega a personas que están comparando productos para developers." })}</p></article>
          <article><span>02</span><h3>{t({ en: "Native placement", es: "Integración nativa" })}</h3><p>{t({ en: "The sponsor module follows the visual language of the site without pretending to be editorial content.", es: "El módulo respeta el diseño de la web sin hacerse pasar por contenido editorial." })}</p></article>
          <article><span>03</span><h3>{t({ en: "Bilingual reach", es: "Alcance bilingüe" })}</h3><p>{t({ en: "We adapt your message for both English- and Spanish-speaking developers.", es: "Adaptamos tu mensaje para developers que hablan inglés y español." })}</p></article>
        </div>
      </section>

      <section class="sponsor-preview" aria-labelledby="preview-title">
        <div class="preview-copy">
          <p class="section-kicker">// YOUR_PLACEMENT</p>
          <h2 id="preview-title">{t({ en: "Clearly sponsored. Beautifully integrated.", es: "Claramente patrocinado. Bien integrado." })}</h2>
          <p>{t({ en: "Trust matters. The placement is always labeled as sponsored and kept separate from organic recommendations.", es: "La confianza importa. El espacio siempre estará marcado como patrocinado y separado de las recomendaciones orgánicas." })}</p>
        </div>
        <div class="preview-card">
          <div class="preview-label"><span>{t({ en: "Sponsored", es: "Patrocinado" })}</span><span>AD*</span></div>
          <div class="preview-logo">YOU</div>
          <div><h3>{t({ en: "Your product belongs here", es: "Tu producto puede estar aquí" })}</h3><p>{t({ en: "A short, useful message explaining why developers should care.", es: "Un mensaje breve y útil que explique por qué debería interesar a developers." })}</p></div>
          <span class="preview-arrow">↗</span>
        </div>
      </section>

      <section class="sponsor-process" aria-labelledby="process-title">
        <div class="sponsor-section-heading">
          <p class="section-kicker">// HOW_IT_WORKS</p>
          <h2 id="process-title">{t({ en: "From hello to live.", es: "Del hola a publicado." })}</h2>
        </div>
        <ol>
          <li><span>01</span><div><h3>{t({ en: "Send the product", es: "Envía el producto" })}</h3><p>{t({ en: "Email the URL, category and preferred campaign date.", es: "Envía por email la URL, categoría y fecha preferida." })}</p></div></li>
          <li><span>02</span><div><h3>{t({ en: "Editorial review", es: "Revisión editorial" })}</h3><p>{t({ en: "We confirm that the product is relevant and prepare the bilingual copy.", es: "Confirmamos que el producto encaja y preparamos el texto bilingüe." })}</p></div></li>
          <li><span>03</span><div><h3>{t({ en: "Payment and preview", es: "Pago y preview" })}</h3><p>{t({ en: "You receive payment details and approve the final placement before launch.", es: "Recibes los datos de pago y apruebas el resultado antes de publicar." })}</p></div></li>
          <li><span>04</span><div><h3>{t({ en: "Go live", es: "Publicación" })}</h3><p>{t({ en: "The exclusive sponsor placement runs for 30 consecutive days.", es: "El espacio exclusivo de sponsor se publica durante 30 días seguidos." })}</p></div></li>
        </ol>
      </section>

      <section class="sponsor-eligibility">
        <p class="section-kicker">// GOOD_FIT</p>
        <div><h2>{t({ en: "Useful products only.", es: "Solo productos útiles." })}</h2><p>{t({ en: "We accept developer tools, SaaS, infrastructure, APIs, education and products relevant to builders. We do not accept gambling, deceptive products or campaigns that compromise user trust.", es: "Aceptamos herramientas para developers, SaaS, infraestructura, APIs, educación y productos relevantes para makers. No aceptamos apuestas, productos engañosos ni campañas que comprometan la confianza del usuario." })}</p></div>
      </section>

      <section class="sponsor-final-cta">
        <span class="sponsor-final-mark">AD*</span>
        <h2>{t({ en: "Ready to be discovered?", es: "¿Listo para que te descubran?" })}</h2>
        <p><span>{t({ en: "Tell us what you are building at", es: "Cuéntanos qué estás construyendo en" })}</span> <a href={contactUrl}>{email}</a></p>
        <a class="primary-cta" href={contactUrl}><span>{t({ en: "Start the conversation", es: "Empezar la conversación" })}</span><span>↗</span></a>
      </section>
    </main>

    <footer class="footer">
      <a class="brand footer-brand" href={localePrefix || "/"}><LogoMark /><span class="brand-name">it's free<span>*</span></span></a>
      <div class="footer-signature"><p><span>{t({ en: "A project by", es: "Un proyecto de" })}</span> <a href="https://midu.dev" target="_blank" rel="noreferrer">midu.dev ↗</a></p><p>{t({ en: "Made for developers who read the pricing page first.", es: "Hecho para developers que leen primero la página de precios." })}</p></div>
      <nav class="social-links" aria-label="midu.dev social networks"><a href="https://twitter.com/midudev" target="_blank" rel="noreferrer">X <span>↗</span></a><a href="https://youtube.com/@midudev" target="_blank" rel="noreferrer">YouTube <span>↗</span></a><a href="https://twitch.tv/midudev" target="_blank" rel="noreferrer">Twitch <span>↗</span></a></nav>
    </footer>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(sponsorStructuredData)} />

  <script>
    const root = document.documentElement
    const themeToggle = document.querySelector<HTMLButtonElement>("#theme-toggle")!
    themeToggle.addEventListener("click", () => {
      const nextTheme = root.dataset.theme === "light" ? "dark" : "light"
      root.dataset.theme = nextTheme
      themeToggle.setAttribute("aria-label", nextTheme === "dark" ? "Use light theme" : "Use dark theme")
      try { localStorage.setItem("itsfree-theme", nextTheme) } catch {}
    })
  </script>
</Layout>
