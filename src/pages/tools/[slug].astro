---
import Layout from "../../layouts/Layout.astro"
import { Code } from "astro:components"
import LogoMark from "../../components/LogoMark.astro"
import CategoryIcon from "../../components/CategoryIcon.astro"
import { categories, getResourceFaviconUrl, resources, sourceReviewedAt, type Resource } from "../../data/resources"
import { buildResourceDetail } from "../../data/resource-details"
import { getCodeExample } from "../../data/code-examples"
import "../../styles/resource-detail.css"

export function getStaticPaths() {
  return resources.map((resource) => ({ params: { slug: resource.slug }, props: { resource, locale: "en" as const } }))
}

interface Props {
  resource: Resource
  locale?: "en" | "es"
}

const { resource, locale = "en" } = Astro.props as Props
const t = <T,>(copy: { en: T; es: T }) => copy[locale]
const localePrefix = locale === "es" ? "/es" : ""
const pagePath = `${localePrefix}/tools/${resource.slug}`
const alternateUrl = locale === "es" ? `/tools/${resource.slug}` : `/es/tools/${resource.slug}`
const detail = buildResourceDetail(resource)
const codeExample = getCodeExample(resource.slug)
const category = categories.find((entry) => entry.id === resource.category)!
const accessLabels = {
  "no-card": { en: "No card required", es: "Sin tarjeta" },
  "no-signup": { en: "No sign-up", es: "Sin registro" },
  "card-for-full-limits": { en: "Card for full limits", es: "Tarjeta para la cuota completa" },
  "trial-only": { en: "Trial only", es: "Solo prueba" },
} as const
const accessLabel = accessLabels[resource.accessRequirement]
const relatedResources = resources
  .filter((candidate) => candidate.category === resource.category && candidate.slug !== resource.slug)
  .map((candidate) => ({
    resource: candidate,
    affinity: candidate.tags.filter((tag) => resource.tags.includes(tag)).length + Number(Boolean(candidate.featured)),
  }))
  .sort((first, second) => second.affinity - first.affinity || first.resource.name.localeCompare(second.resource.name))
  .slice(0, 4)
  .map(({ resource }) => resource)
const faviconUrl = getResourceFaviconUrl(resource)
const screenshotUrl = `https://api.sitelookeratter.com/screenshot?url=${encodeURIComponent(resource.url)}&device=desktop&format=webp&darkMode=true&removeCookies=true&blockAds=true&removeChat=true&removePopups=true`
const reviewedDate = new Intl.DateTimeFormat(locale, { day: "numeric", month: "long", year: "numeric" }).format(new Date(`${sourceReviewedAt}T12:00:00Z`))
const pageUrl = `https://itsfree.dev${pagePath}`
const pageDescription = t({
  en: `Review ${resource.name}'s free tier, current limits, pricing, access requirements, practical use cases and developer alternatives.`,
  es: `Analiza el plan gratuito de ${resource.name}, sus límites, precios, requisitos, casos de uso y alternativas para developers.`,
})
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: t({ en: `${resource.name} free tier, limits and pricing`, es: `Plan gratuito, límites y precios de ${resource.name}` }),
      description: pageDescription,
      dateModified: sourceReviewedAt,
      inLanguage: locale,
      isPartOf: { "@id": "https://itsfree.dev/#website" },
      mainEntity: { "@id": `${pageUrl}#software` },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: t({ en: "Directory", es: "Directorio" }), item: `https://itsfree.dev${localePrefix || "/"}` },
        { "@type": "ListItem", position: 2, name: category.name[locale], item: `https://itsfree.dev${localePrefix || "/"}#directory` },
        { "@type": "ListItem", position: 3, name: resource.name, item: pageUrl },
      ],
    },
    {
      "@type": "SoftwareApplication",
      "@id": `${pageUrl}#software`,
      name: resource.name,
      url: resource.url,
      sameAs: resource.url,
      applicationCategory: "DeveloperApplication",
      applicationSubCategory: category.name[locale],
      operatingSystem: "Web",
      description: resource.description[locale],
      isAccessibleForFree: resource.accessRequirement !== "trial-only",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: resource.freeTier[locale], url: resource.pricingUrl },
    },
  ],
}
---

<Layout title={t({ en: `${resource.name} free tier & pricing | it's free*`, es: `Plan gratuito y precios de ${resource.name} | it's free*` })} description={pageDescription} locale={locale} canonical={pagePath} alternate={alternateUrl}>
  <div class="site-shell detail-shell">
    <header class="topbar">
      <a class="brand" href={localePrefix || "/"} aria-label="it's free home">
        <LogoMark />
        <span class="brand-name">it's free<span>*</span></span>
      </a>
      <nav class="topbar-nav" aria-label="Primary navigation">
        <a href={`${localePrefix || "/"}#directory`}>{t({ en: "Directory", es: "Directorio" })}</a>
        <a class="active-link" href={pagePath}>{t({ en: "Resource", es: "Recurso" })}</a>
        <a href={`${localePrefix}/sponsor`}>{t({ en: "Sponsor", es: "Patrocinar" })}</a>
      </nav>
      <div class="topbar-actions">
        <button class="icon-button" id="theme-toggle" type="button" aria-label="Use light theme">
          <svg class="sun-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path></svg>
          <svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.4 15.5A8.4 8.4 0 0 1 8.5 3.6 8.4 8.4 0 1 0 20.4 15.5Z"></path></svg>
        </button>
        <a class="language-button" href={alternateUrl} lang={locale === "es" ? "en" : "es"} hreflang={locale === "es" ? "en" : "es"} aria-label={t({ en: "Cambiar a español", es: "Switch to English" })}>{locale === "es" ? "EN" : "ES"}</a>
      </div>
    </header>

    <main class="detail-main">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href={localePrefix || "/"}>{t({ en: "Directory", es: "Directorio" })}</a><span>/</span>
        <a href={`${localePrefix || "/"}#directory`}>{t({ en: category.name.en, es: category.name.es })}</a><span>/</span>
        <strong>{resource.name}</strong>
      </nav>

      <div class="detail-intro-grid">
        <section class="detail-hero">
          <div class="detail-identity">
            <span class="detail-logo">
              <img src={faviconUrl} alt="" width="48" height="48" referrerpolicy="no-referrer" />
            </span>
            <div>
              <p class="section-kicker">// RESOURCE_PROFILE</p>
              <h1>{resource.name}</h1>
              <p class="detail-category">{t({ en: category.name.en, es: category.name.es })}</p>
            </div>
          </div>
          <p class="detail-hero-summary">{t({ en: resource.description.en, es: resource.description.es })}</p>
          <div class="detail-actions">
            <a class="primary-visit" href={resource.url} target="_blank" rel="noreferrer">
              <span>{t({ en: `Visit ${resource.name}`, es: `Visitar ${resource.name}` })}</span><span>↗</span>
            </a>
            <a class="back-directory" href={`${localePrefix || "/"}#directory`}>{t({ en: "Back to directory", es: "Volver al directorio" })}</a>
          </div>
        </section>

        <section class="screenshot-section" aria-labelledby="preview-title">
          <div class="section-heading-compact">
            <div><p class="section-kicker">// LIVE_PREVIEW</p><h2 id="preview-title">{t({ en: "Official website", es: "Web oficial" })}</h2></div>
          </div>
          <figure class="site-screenshot">
            <div class="browser-chrome" aria-hidden="true"><i></i><i></i><i></i><span>{new URL(resource.url).hostname}</span></div>
            <div class="screenshot-frame">
              <div class="screenshot-fallback" aria-hidden="true"><img src={faviconUrl} alt="" referrerpolicy="no-referrer" /><strong>{resource.name}</strong><span>{t({ en: "Preview temporarily unavailable", es: "Preview no disponible temporalmente" })}</span></div>
              <img data-screenshot src={screenshotUrl} alt={`Screenshot of the ${resource.name} website`} loading="eager" decoding="async" referrerpolicy="no-referrer" />
            </div>
            <figcaption><span>{t({ en: "Website preview", es: "Vista previa de la web" })}</span><a href={resource.url} target="_blank" rel="noreferrer">{new URL(resource.url).hostname} ↗</a></figcaption>
          </figure>
        </section>
      </div>

      <div class="detail-layout">
        <article class="detail-content">
          <section class="content-section" aria-labelledby="about-resource">
            <p class="section-kicker">// THE_SHORT_VERSION</p>
            <h2 id="about-resource">{t({ en: `What is ${resource.name}?`, es: `¿Qué es ${resource.name}?` })}</h2>
            {detail.longDescription.en.map((paragraph, index) => <p>{t({ en: paragraph, es: detail.longDescription.es[index] })}</p>)}
          </section>

          <section class="content-section" aria-labelledby="use-cases">
            <p class="section-kicker">// WHEN_IT_FITS</p>
            <h2 id="use-cases">{t({ en: "Practical use cases", es: "Casos de uso prácticos" })}</h2>
            <div class="use-case-grid">
              {detail.useCases.en.map((useCase, index) => (
                <div class="use-case"><span>0{index + 1}</span><p>{t({ en: useCase, es: detail.useCases.es[index] })}</p></div>
              ))}
            </div>
          </section>

          <section class="content-section example-section" aria-labelledby="example-title">
            <p class="section-kicker">// TRY_THIS_FIRST</p>
            <h2 id="example-title">{t({ en: detail.exampleTitle.en, es: detail.exampleTitle.es })}</h2>
            <ol class="example-steps">
              {detail.exampleSteps.en.map((step, index) => (
                <li><span>{index + 1}</span><p>{t({ en: step, es: detail.exampleSteps.es[index] })}</p></li>
              ))}
            </ol>
          </section>

          {codeExample && (
            <section class="content-section code-example-section" aria-labelledby="code-example-title">
              <p class="section-kicker">// QUICK_START</p>
              <h2 id="code-example-title">{codeExample.title[locale]}</h2>
              <p>{codeExample.description[locale]}</p>
              <div class="code-window">
                <div class="code-window-bar">
                  <span aria-hidden="true"><i></i><i></i><i></i></span>
                  <strong>{codeExample.filename}</strong>
                  <small>{codeExample.lang}</small>
                </div>
                <Code code={codeExample.code} lang={codeExample.lang} theme="github-dark" />
              </div>
            </section>
          )}

          <section class="content-section" aria-labelledby="before-choosing">
            <p class="section-kicker">// READ_BEFORE_USING</p>
            <h2 id="before-choosing">{t({ en: "What to check before committing", es: "Qué revisar antes de elegirlo" })}</h2>
            <div class="caveat-list">
              {detail.caveats.en.map((caveat, index) => <p>{t({ en: caveat, es: detail.caveats.es[index] })}</p>)}
            </div>
          </section>
        </article>

        <aside class="fact-panel">
          <p class="section-kicker">// FREE_PLAN_AT_A_GLANCE</p>
          <div class:list={["access-badge", { "is-trial": resource.accessRequirement === "trial-only", "is-card-required": resource.accessRequirement === "card-for-full-limits" }]}>{t({ en: accessLabel.en, es: accessLabel.es })}</div>
          <div class="free-allowance"><span>{t({ en: "Included at no cost", es: "Incluido sin coste" })}</span><p>{t({ en: resource.freeTier.en, es: resource.freeTier.es })}</p></div>
          <dl>
            <div><dt>{t({ en: "Best for", es: "Ideal para" })}</dt><dd>{t({ en: detail.idealFor.en, es: detail.idealFor.es })}</dd></div>
            <div><dt>{t({ en: "Category", es: "Categoría" })}</dt><dd>{t({ en: category.name.en, es: category.name.es })}</dd></div>
            <div><dt>{t({ en: "Last reviewed", es: "Última revisión" })}</dt><dd>{reviewedDate}</dd></div>
          </dl>
          <div class="fact-tags">{resource.tags.map((tag) => <span>{tag}</span>)}</div>
          <a href={resource.pricingUrl} target="_blank" rel="noreferrer"><span>{t({ en: "Check current pricing", es: "Comprobar precios actuales" })}</span> ↗</a>
        </aside>
      </div>

      <section class="related-section" aria-labelledby="related-title">
        <div class="section-heading-compact">
          <div><p class="section-kicker">// KEEP_EXPLORING</p><h2 id="related-title">{t({ en: `Alternatives to ${resource.name}`, es: `Alternativas a ${resource.name}` })}</h2></div>
          <a href={`${localePrefix || "/"}#directory`}>{t({ en: "View the whole category →", es: "Ver toda la categoría →" })}</a>
        </div>
        <div class="related-grid">
          {relatedResources.map((related) => (
            <article class="related-card">
              <div><img src={getResourceFaviconUrl(related)} alt="" width="28" height="28" referrerpolicy="no-referrer" /><CategoryIcon name={category.icon} size={18} /></div>
              <h3>{related.name}</h3>
              <p>{t({ en: related.description.en, es: related.description.es })}</p>
              <div>{related.tags.slice(0, 2).map((tag) => <span>{tag}</span>)}</div>
              <a href={`${localePrefix}/tools/${related.slug}`} aria-label={t({ en: `Read about ${related.name}`, es: `Leer sobre ${related.name}` })}></a>
            </article>
          ))}
        </div>
      </section>
    </main>

    <footer class="footer detail-footer">
      <a class="brand footer-brand" href={localePrefix || "/"}><LogoMark /><span class="brand-name">it's free<span>*</span></span></a>
      <div class="footer-signature"><p>{t({ en: "Independent notes about genuinely useful free plans.", es: "Notas independientes sobre planes gratuitos realmente útiles." })}</p><p>{t({ en: "Always confirm limits with the provider before production use.", es: "Confirma siempre los límites con el proveedor antes de usarlo en producción." })}</p></div>
      <a class="footer-directory-link" href={`${localePrefix || "/"}#directory`}>{t({ en: "Explore all resources →", es: "Explorar todos los recursos →" })}</a>
    </footer>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <script>
    const root = document.documentElement
    const themeToggle = document.querySelector<HTMLButtonElement>("#theme-toggle")!

    function applyTheme(theme: "light" | "dark") {
      root.dataset.theme = theme
      themeToggle.setAttribute("aria-label", theme === "dark" ? "Use light theme" : "Use dark theme")
      try { localStorage.setItem("itsfree-theme", theme) } catch {}
    }

    themeToggle.addEventListener("click", () => applyTheme(root.dataset.theme === "light" ? "dark" : "light"))
    document.querySelectorAll<HTMLImageElement>("[data-screenshot]").forEach((image) => image.addEventListener("error", () => image.classList.add("is-unavailable")))
    applyTheme(root.dataset.theme === "light" ? "light" : "dark")
  </script>
</Layout>
