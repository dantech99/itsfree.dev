---
import Layout from "../layouts/Layout.astro"
import LogoMark from "../components/LogoMark.astro"
import CategoryIcon from "../components/CategoryIcon.astro"
import { categories, getResourceFaviconUrl, resources, sourceReviewedAt } from "../data/resources"

const totalResources = resources.length
const featuredResources = resources.filter((resource) => resource.featured).length
const featuredOrder = ["InsForge", "CodeRabbit", "Cloudflare", "Vercel"]
const featuredRank = new Map(featuredOrder.map((name, index) => [name, index]))
const sortedResources = [...resources].sort((first, second) => {
  const featuredDifference = Number(Boolean(second.featured)) - Number(Boolean(first.featured))
  if (featuredDifference !== 0) return featuredDifference

  const firstRank = featuredRank.get(first.name) ?? Number.POSITIVE_INFINITY
  const secondRank = featuredRank.get(second.name) ?? Number.POSITIVE_INFINITY
  return firstRank - secondRank
})
const reviewedDate = new Intl.DateTimeFormat("en", {
  month: "short",
  year: "numeric",
}).format(new Date(`${sourceReviewedAt}T12:00:00Z`))

const categoryMap = new Map(categories.map((category) => [category.id, category]))
const accessLabels = {
  "no-card": { en: "No card required", es: "Sin tarjeta" },
  "no-signup": { en: "No sign-up", es: "Sin registro" },
  "card-for-full-limits": { en: "Card for full limits", es: "Tarjeta para la cuota completa" },
  "trial-only": { en: "Trial only", es: "Solo prueba" },
} as const
const cleanFreeTierPrefix = (copy: string, locale: "en" | "es") => locale === "es"
  ? copy.replace(/^Gratis(?: para siempre)?:\s*/i, "")
  : copy.replace(/^Free(?: forever)?:\s*/i, "")
const categoryCounts = new Map(
  categories.map((category) => [
    category.id,
    resources.filter((resource) => resource.category === category.id).length,
  ]),
)
const siteUrl = "https://itsfree.dev"
const homeDescription = "A curated bilingual directory of genuinely useful free developer tools, APIs, hosting, databases, AI models and more."
const faqEntries = [
  {
    question: "Are all these tools completely free?",
    answer: "Every product listed offers a useful free tier, but it may include usage, storage or team limits. It is not the same as an unlimited free product.",
  },
  {
    question: "Do I need a credit card?",
    answer: "Most resources do not require one. Every listing clearly identifies when a card is needed to unlock the complete free allowance.",
  },
  {
    question: "How often is the directory updated?",
    answer: "The catalog is reviewed regularly, adding useful discoveries and removing products whose free offer is no longer relevant.",
  },
  {
    question: "Why is the site available in two languages?",
    answer: "Great developer tools should be easy to discover in both English and Spanish. Language preference is saved automatically.",
  },
]
const homeStructuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: "it's free*",
      alternateName: "itsfree.dev",
      url: `${siteUrl}/`,
      description: homeDescription,
      inLanguage: ["en", "es"],
      publisher: { "@type": "Organization", name: "midu.dev", url: "https://midu.dev" },
    },
    {
      "@type": "CollectionPage",
      "@id": `${siteUrl}/#directory`,
      url: `${siteUrl}/`,
      name: "Free tools for developers",
      description: homeDescription,
      dateModified: sourceReviewedAt,
      isPartOf: { "@id": `${siteUrl}/#website` },
      mainEntity: {
        "@type": "ItemList",
        numberOfItems: resources.length,
        itemListElement: sortedResources.map((resource, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: resource.name,
          url: `${siteUrl}/tools/${resource.slug}`,
        })),
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: faqEntries.map((entry) => ({
        "@type": "Question",
        name: entry.question,
        acceptedAnswer: { "@type": "Answer", text: entry.answer },
      })),
    },
  ],
}
---

<Layout
  title="it's free* — Free tools for developers"
  description={homeDescription}
>
  <div class="site-shell">
    <header class="topbar">
      <a class="brand" href="#top" aria-label="it's free home">
        <LogoMark />
        <span class="brand-name">it's free<span>*</span></span>
      </a>

      <nav class="topbar-nav" aria-label="Primary navigation">
        <a href="#directory" data-i18n data-en="Explore" data-es="Explorar">Explore</a>
        <a href="#about" data-i18n data-en="About" data-es="Sobre el proyecto">About</a>
        <a href="/sponsor" data-i18n data-en="Sponsor" data-es="Patrocinar">Sponsor</a>
      </nav>

      <div class="topbar-actions">
        <button class="icon-button" id="theme-toggle" type="button" aria-label="Use light theme">
          <svg class="sun-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path></svg>
          <svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.4 15.5A8.4 8.4 0 0 1 8.5 3.6 8.4 8.4 0 1 0 20.4 15.5Z"></path></svg>
        </button>
        <button class="language-button" id="language-toggle" type="button" aria-label="Cambiar a español">ES</button>
      </div>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-glow" aria-hidden="true"></div>
        <p class="eyebrow"><span class="status-dot"></span><span data-i18n data-en="The good part of the internet" data-es="La parte buena de internet">The good part of the internet</span></p>
        <h1 id="hero-title">
          <span data-i18n data-en="Build more." data-es="Construye más.">Build more.</span>
          <span class="hero-accent" data-i18n data-en="Spend less." data-es="Gasta menos.">Spend less.</span>
        </h1>
        <p class="hero-copy" data-i18n data-en="A carefully selected catalog of products with genuinely useful free tiers for developers, makers and small teams." data-es="Un catálogo cuidadosamente seleccionado de productos con capas gratuitas realmente útiles para developers, makers y pequeños equipos.">
          A carefully selected catalog of products with genuinely useful free tiers for developers, makers and small teams.
        </p>

        <div class="hero-stats" aria-label="Directory statistics">
          <div><strong>{totalResources}</strong><span data-i18n data-en="resources" data-es="recursos">resources</span></div>
          <div><strong>{categories.length}</strong><span data-i18n data-en="categories" data-es="categorías">categories</span></div>
          <div><strong>{featuredResources}</strong><span data-i18n data-en="editor's picks" data-es="recomendados">editor's picks</span></div>
          <div><strong>{reviewedDate}</strong><span data-i18n data-en="last review" data-es="última revisión">last review</span></div>
        </div>
      </section>

      <section class="directory" id="directory" aria-labelledby="directory-title">
        <div class="directory-heading">
          <div>
            <p class="section-kicker">// DIRECTORY_01</p>
            <h2 id="directory-title" data-i18n data-en="Find your next tool" data-es="Encuentra tu próxima herramienta">Find your next tool</h2>
          </div>
          <p data-i18n data-en="Search by product, use case or technology." data-es="Busca por producto, caso de uso o tecnología.">Search by product, use case or technology.</p>
        </div>

        <div class="search-panel">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-4-4"></path></svg>
          <input
            id="search-input"
            type="search"
            autocomplete="off"
            spellcheck="false"
            placeholder={`Search ${totalResources} free resources...`}
            data-placeholder-en={`Search ${totalResources} free resources...`}
            data-placeholder-es={`Busca entre ${totalResources} recursos gratis...`}
            aria-label="Search resources"
          />
          <kbd>/</kbd>
        </div>

        <div class="mobile-categories" aria-label="Resource categories">
          <button class="mobile-category active" type="button" data-category="all">
            <CategoryIcon name="layout-grid" size={14} />
            <span data-i18n data-en="All" data-es="Todo">All</span>
          </button>
          {categories.map((category) => (
            <button class="mobile-category" type="button" data-category={category.id}>
              <CategoryIcon name={category.icon} size={14} />
              <span data-en={category.name.en} data-es={category.name.es} data-i18n>{category.name.en}</span>
            </button>
          ))}
        </div>

        <div class="catalog-layout">
          <aside class="category-sidebar">
            <div class="category-label" data-i18n data-en="Browse by category" data-es="Explora por categoría">Browse by category</div>
            <button class="category-button active" type="button" data-category="all">
              <span class="category-icon"><CategoryIcon name="layout-grid" /></span>
              <span data-i18n data-en="All resources" data-es="Todos los recursos">All resources</span>
              <small>{totalResources}</small>
            </button>
            {categories.map((category) => (
              <button class="category-button" type="button" data-category={category.id}>
                <span class="category-icon"><CategoryIcon name={category.icon} /></span>
                <span data-i18n data-en={category.name.en} data-es={category.name.es}>{category.name.en}</span>
                <small>{categoryCounts.get(category.id)}</small>
              </button>
            ))}
            <a class="sponsor-mini" href="/sponsor">
              <span class="sponsor-mini-mark">AD*</span>
              <span>
                <strong data-i18n data-en="Sponsor this directory" data-es="Patrocina este directorio">Sponsor this directory</strong>
                <small data-i18n data-en="€1,500 / 30 days →" data-es="1.500 € / 30 días →">€1,500 / 30 days →</small>
              </span>
            </a>
          </aside>

          <div class="results-column">
            <div class="results-toolbar">
              <p><span id="results-count">{totalResources}</span> <span data-i18n data-en="resources found" data-es="recursos encontrados">resources found</span></p>
            </div>

            <div class="resource-grid" id="resource-grid">
              {sortedResources.map((resource) => {
                const category = categoryMap.get(resource.category)!
                const accessLabel = accessLabels[resource.accessRequirement]
                const freeTierEn = cleanFreeTierPrefix(resource.freeTier.en, "en")
                const freeTierEs = cleanFreeTierPrefix(resource.freeTier.es, "es")
                const initials = resource.name.split(/\s+/).map((word) => word[0]).join("").slice(0, 2).toUpperCase()
                const faviconUrl = getResourceFaviconUrl(resource)
                const searchable = [resource.name, resource.description.en, resource.description.es, resource.freeTier.en, resource.freeTier.es, ...resource.tags, category.name.en, category.name.es].join(" ").toLowerCase()
                return (
                  <article class={`resource-card${resource.featured ? " is-featured" : ""}`} data-resource data-category={resource.category} data-name={resource.name} data-search={searchable}>
                    {resource.featured && <span class="featured-corner" title="Editor's pick">✦</span>}
                    <div class="card-topline">
                      <span class="resource-logo" aria-hidden="true">
                        <span class="resource-initials">{initials}</span>
                        <img src={faviconUrl} alt="" width="28" height="28" loading="lazy" decoding="async" referrerpolicy="no-referrer" />
                      </span>
                      <h3>{resource.name}</h3>
                      <a class="card-arrow card-external-link" href={resource.url} target="_blank" rel="noreferrer" aria-label={`Open ${resource.name} website`}>↗</a>
                    </div>
                    <div class="card-body">
                      <p data-i18n data-en={resource.description.en} data-es={resource.description.es}>{resource.description.en}</p>
                      <div class="free-tier">
                        <span
                          class:list={{
                            "is-trial": resource.accessRequirement === "trial-only",
                            "is-card-required": resource.accessRequirement === "card-for-full-limits",
                          }}
                          data-i18n
                          data-en={accessLabel.en}
                          data-es={accessLabel.es}
                        >{accessLabel.en}</span>
                        <p data-i18n data-en={freeTierEn} data-es={freeTierEs}>{freeTierEn}</p>
                      </div>
                    </div>
                    <div class="card-footer">
                      <div class="tags">{resource.tags.slice(0, 2).map((tag) => <span>{tag}</span>)}</div>
                    </div>
                    <a class="card-link" href={`/tools/${resource.slug}`} aria-label={`Read about ${resource.name}`}></a>
                  </article>
                )
              })}
            </div>

            <div class="empty-state" id="empty-state" hidden>
              <span>Ø</span>
              <h3 data-i18n data-en="Nothing found in this corner." data-es="No hay nada por este rincón.">Nothing found in this corner.</h3>
              <p data-i18n data-en="Try another search or explore all categories." data-es="Prueba otra búsqueda o explora todas las categorías.">Try another search or explore all categories.</p>
              <button id="reset-filters" type="button" data-i18n data-en="Reset filters" data-es="Limpiar filtros">Reset filters</button>
            </div>
          </div>
        </div>
      </section>

      <section class="about-strip" id="about">
        <p class="section-kicker">// OPEN_WEB</p>
        <div>
          <h2 data-i18n data-en="Free should be easy to find." data-es="Lo gratis debería ser fácil de encontrar.">Free should be easy to find.</h2>
          <p data-i18n data-en="An independent bilingual directory built to make genuinely useful free tools easier to discover. We review every entry and keep the catalog focused on products developers can actually use." data-es="Un directorio bilingüe e independiente creado para descubrir herramientas gratuitas realmente útiles. Revisamos cada entrada y mantenemos el catálogo centrado en productos que un developer puede usar de verdad.">
            An independent bilingual directory built to make genuinely useful free tools easier to discover. We review every entry and keep the catalog focused on products developers can actually use.
          </p>
        </div>
        <a href="#directory"><span data-i18n data-en="Explore the catalog" data-es="Explorar el catálogo">Explore the catalog</span><span>↓</span></a>
      </section>

      <section class="faq-section" id="faq" aria-labelledby="faq-title">
        <div class="faq-intro">
          <p class="section-kicker">// FAQ_04</p>
          <h2 id="faq-title" data-i18n data-en="Questions, answered." data-es="Preguntas, resueltas.">Questions, answered.</h2>
          <p data-i18n data-en="The small print, without making it small." data-es="La letra pequeña, sin hacerla pequeña.">The small print, without making it small.</p>
        </div>

        <div class="faq-list">
          <details open>
            <summary><span data-i18n data-en="Are all these tools completely free?" data-es="¿Todas estas herramientas son completamente gratis?">Are all these tools completely free?</span><span class="faq-toggle">＋</span></summary>
            <p data-i18n data-en="Every product listed offers a useful free tier, but it may include usage, storage or team limits. It is not the same as an unlimited free product." data-es="Todos los productos ofrecen una capa gratuita útil, aunque puede tener límites de uso, almacenamiento o equipo. No significa que sean productos gratuitos sin límites.">Every product listed offers a useful free tier, but it may include usage, storage or team limits. It is not the same as an unlimited free product.</p>
          </details>
          <details>
            <summary><span data-i18n data-en="How do you choose what gets listed?" data-es="¿Cómo elegís qué aparece en el listado?">How do you choose what gets listed?</span><span class="faq-toggle">＋</span></summary>
            <p data-i18n data-en="We prioritize reliable tools with a free plan that is genuinely useful for building, learning or launching a real project." data-es="Priorizamos herramientas fiables con un plan gratuito que sea realmente útil para construir, aprender o lanzar un proyecto real.">We prioritize reliable tools with a free plan that is genuinely useful for building, learning or launching a real project.</p>
          </details>
          <details>
            <summary><span data-i18n data-en="Can I use these services in production?" data-es="¿Puedo usar estos servicios en producción?">Can I use these services in production?</span><span class="faq-toggle">＋</span></summary>
            <p data-i18n data-en="Often yes, especially for small apps. Check current limits, support, data location and upgrade costs with the provider before making a production decision." data-es="A menudo sí, especialmente en aplicaciones pequeñas. Comprueba límites, soporte, ubicación de datos y costes de ampliación antes de decidir.">Often yes, especially for small apps. Check current limits, support, data location and upgrade costs with the provider before making a production decision.</p>
          </details>
          <details>
            <summary><span data-i18n data-en="How often is the directory reviewed?" data-es="¿Cada cuánto se revisa el directorio?">How often is the directory reviewed?</span><span class="faq-toggle">＋</span></summary>
            <p data-i18n data-en="We review the catalog regularly, add useful discoveries and remove products whose free offer is no longer relevant." data-es="Revisamos el catálogo regularmente, añadimos descubrimientos útiles y retiramos productos cuya oferta gratuita deja de ser relevante.">We review the catalog regularly, add useful discoveries and remove products whose free offer is no longer relevant.</p>
          </details>
          <details>
            <summary><span data-i18n data-en="Why is the site available in two languages?" data-es="¿Por qué está disponible en dos idiomas?">Why is the site available in two languages?</span><span class="faq-toggle">＋</span></summary>
            <p data-i18n data-en="Great developer tools should be easy to discover in both English and Spanish. Your language preference is saved automatically." data-es="Las buenas herramientas para developers deberían ser fáciles de descubrir en inglés y español. Tu preferencia se guarda automáticamente.">Great developer tools should be easy to discover in both English and Spanish. Your language preference is saved automatically.</p>
          </details>
        </div>
      </section>
    </main>

    <footer class="footer">
      <a class="brand footer-brand" href="#top"><LogoMark /><span class="brand-name">it's free<span>*</span></span></a>
      <div class="footer-signature">
        <p><span data-i18n data-en="A project by" data-es="Un proyecto de">A project by</span> <a href="https://midu.dev" target="_blank" rel="noreferrer">midu.dev ↗</a></p>
        <p data-i18n data-en="Made for developers who read the pricing page first." data-es="Hecho para developers que leen primero la página de precios.">Made for developers who read the pricing page first.</p>
      </div>
      <nav class="social-links" aria-label="midu.dev social networks">
        <a href="https://twitter.com/midudev" target="_blank" rel="noreferrer" aria-label="X / Twitter">X <span>↗</span></a>
        <a href="https://youtube.com/@midudev" target="_blank" rel="noreferrer" aria-label="YouTube">YouTube <span>↗</span></a>
        <a href="https://twitch.tv/midudev" target="_blank" rel="noreferrer" aria-label="Twitch">Twitch <span>↗</span></a>
        <a href="https://github.com/midudev" target="_blank" rel="noreferrer" aria-label="GitHub">GitHub <span>↗</span></a>
      </nav>
    </footer>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(homeStructuredData)} />

  <script>
    const root = document.documentElement
    const searchInput = document.querySelector<HTMLInputElement>("#search-input")!
    const resourceCards = [...document.querySelectorAll<HTMLElement>("[data-resource]")]
    const categoryButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-category]")]
    const resultsCount = document.querySelector<HTMLElement>("#results-count")!
    const emptyState = document.querySelector<HTMLElement>("#empty-state")!
    const languageToggle = document.querySelector<HTMLButtonElement>("#language-toggle")!
    const themeToggle = document.querySelector<HTMLButtonElement>("#theme-toggle")!

    document.querySelectorAll<HTMLImageElement>(".resource-logo img").forEach((image) => {
      const useFallback = () => {
        image.parentElement?.classList.add("favicon-fallback")
        image.remove()
      }
      image.addEventListener("error", useFallback)
      if (image.complete && image.naturalWidth === 0) useFallback()
    })

    let activeCategory = "all"

    const getLocale = () => root.lang === "es" ? "es" : "en"
    const normalizeSearch = (value: string) => value
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, " ")
      .trim()
    const compactSearch = (value: string) => normalizeSearch(value).replace(/\s+/g, "")

    function applyLocale(locale: "en" | "es") {
      root.lang = locale
      document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((element) => {
        const translation = locale === "es" ? element.dataset.es : element.dataset.en
        if (translation) element.textContent = translation
      })
      searchInput.placeholder = locale === "es"
        ? searchInput.dataset.placeholderEs ?? ""
        : searchInput.dataset.placeholderEn ?? ""
      searchInput.setAttribute("aria-label", locale === "es" ? "Buscar recursos" : "Search resources")
      languageToggle.textContent = locale === "es" ? "EN" : "ES"
      languageToggle.setAttribute("aria-label", locale === "es" ? "Switch to English" : "Cambiar a español")
      try { localStorage.setItem("itsfree-locale", locale) } catch {}
    }

    function applyFilters() {
      const query = normalizeSearch(searchInput.value)
      const compactQuery = compactSearch(searchInput.value)
      let visible = 0

      resourceCards.forEach((card) => {
        const matchesCategory = activeCategory === "all" || card.dataset.category === activeCategory
        const searchable = normalizeSearch(card.dataset.search ?? "")
        const name = card.dataset.name ?? ""
        const matchesName = normalizeSearch(name).includes(query) || compactSearch(name).includes(compactQuery)
        const matchesQuery = !query || matchesName || searchable.includes(query)
        const show = matchesCategory && matchesQuery
        card.hidden = !show
        if (show) visible += 1
      })

      resultsCount.textContent = String(visible)
      emptyState.hidden = visible !== 0
    }

    function selectCategory(category: string) {
      activeCategory = category
      categoryButtons.forEach((button) => button.classList.toggle("active", button.dataset.category === category))
      applyFilters()
    }

    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        selectCategory(button.dataset.category ?? "all")
        requestAnimationFrame(() => {
          document.querySelector("#resource-grid")?.scrollIntoView({
            behavior: window.matchMedia("(prefers-reduced-motion: reduce)").matches ? "auto" : "smooth",
            block: "start",
          })
        })
      })
    })

    searchInput.addEventListener("input", () => {
      if (searchInput.value.trim() && activeCategory !== "all") selectCategory("all")
      else applyFilters()
    })
    document.querySelector("#reset-filters")?.addEventListener("click", () => {
      searchInput.value = ""
      selectCategory("all")
      searchInput.focus()
    })

    languageToggle.addEventListener("click", () => applyLocale(getLocale() === "en" ? "es" : "en"))
    themeToggle.addEventListener("click", () => {
      const nextTheme = root.dataset.theme === "light" ? "dark" : "light"
      root.dataset.theme = nextTheme
      themeToggle.setAttribute("aria-label", nextTheme === "dark" ? "Use light theme" : "Use dark theme")
      try { localStorage.setItem("itsfree-theme", nextTheme) } catch {}
    })

    document.addEventListener("keydown", (event) => {
      if (event.key === "/" && document.activeElement !== searchInput) {
        event.preventDefault()
        searchInput.focus()
      }
      if (event.key === "Escape" && document.activeElement === searchInput) {
        searchInput.value = ""
        applyFilters()
        searchInput.blur()
      }
    })

    applyLocale(getLocale())
    applyFilters()
  </script>
</Layout>
