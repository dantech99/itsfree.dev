---
import Layout from "../layouts/Layout.astro"
import LogoMark from "../components/LogoMark.astro"
import CategoryIcon from "../components/CategoryIcon.astro"
import { categories, getResourceFaviconUrl, resources, sourceReviewedAt } from "../data/resources"

interface Props {
  locale?: "en" | "es"
  categoryId?: string
}

const { locale = "en", categoryId } = Astro.props as Props
const t = <T,>(copy: { en: T; es: T }) => copy[locale]
const localePrefix = locale === "es" ? "/es" : ""
const selectedCategory = categoryId ? categories.find((category) => category.id === categoryId) : undefined
const pagePath = selectedCategory ? `${localePrefix}/categories/${selectedCategory.id}` : (localePrefix || "/")
const alternateUrl = selectedCategory
  ? `${locale === "es" ? "" : "/es"}/categories/${selectedCategory.id}`
  : locale === "es" ? "/" : "/es"
const languageSwitchUrl = `/language/${locale === "es" ? "en" : "es"}?redirect=${encodeURIComponent(alternateUrl)}`

const pageResources = selectedCategory ? resources.filter((resource) => resource.category === selectedCategory.id) : resources
const totalResources = pageResources.length
const featuredResources = pageResources.filter((resource) => resource.featured).length
const featuredOrder = ["InsForge", "CodeRabbit", "Cloudflare", "Vercel"]
const featuredRank = new Map(featuredOrder.map((name, index) => [name, index]))
const sortedResources = [...pageResources].sort((first, second) => {
  const featuredDifference = Number(Boolean(second.featured)) - Number(Boolean(first.featured))
  if (featuredDifference !== 0) return featuredDifference

  const firstRank = featuredRank.get(first.name) ?? Number.POSITIVE_INFINITY
  const secondRank = featuredRank.get(second.name) ?? Number.POSITIVE_INFINITY
  return firstRank - secondRank
})
const reviewedDate = new Intl.DateTimeFormat(locale, {
  month: "short",
  year: "numeric",
}).format(new Date(`${sourceReviewedAt}T12:00:00Z`))

const categoryMap = new Map(categories.map((category) => [category.id, category]))
const accessLabels = {
  "no-card": { en: "No card required", es: "Sin tarjeta" },
  "no-signup": { en: "No sign-up", es: "Sin registro" },
  "card-for-full-limits": { en: "Card for full limits", es: "Tarjeta para la cuota completa" },
  "trial-only": { en: "Trial only", es: "Solo prueba" },
} as const
const cleanFreeTierPrefix = (copy: string, locale: "en" | "es") => locale === "es"
  ? copy.replace(/^Gratis(?: para siempre)?:\s*/i, "")
  : copy.replace(/^Free(?: forever)?:\s*/i, "")
const categoryCounts = new Map(
  categories.map((category) => [
    category.id,
    resources.filter((resource) => resource.category === category.id).length,
  ]),
)
const siteUrl = "https://itsfree.dev"
const homeDescription = selectedCategory ? t({
  en: `A curated selection of genuinely useful free ${selectedCategory.name.en.toLowerCase()} tools and services for developers.`,
  es: `Una selección curada de herramientas y servicios gratis de ${selectedCategory.name.es.toLowerCase()} realmente útiles para developers.`,
}) : t({
  en: "A curated directory of genuinely useful free developer tools, APIs, hosting, databases, AI models and more.",
  es: "Un directorio seleccionado de herramientas gratuitas realmente útiles para developers: APIs, hosting, bases de datos, modelos de IA y más.",
})
const pageTitle = selectedCategory
  ? t({ en: `Best free ${selectedCategory.name.en} tools for developers`, es: `Mejores herramientas gratis de ${selectedCategory.name.es} para developers` })
  : t({ en: "it's free* — Free tools for developers", es: "it's free* — Herramientas gratis para developers" })
const faqEntries = locale === "es" ? [
  {
    question: "¿Todas estas herramientas son completamente gratis?",
    answer: "Todos los productos ofrecen una capa gratuita útil, aunque puede tener límites de uso, almacenamiento o equipo. No significa que sean productos gratuitos sin límites.",
  },
  {
    question: "¿Necesito una tarjeta de crédito?",
    answer: "La mayoría de los recursos no la requieren. Cada ficha indica claramente cuándo hace falta una tarjeta para acceder a toda la cuota gratuita.",
  },
  {
    question: "¿Cada cuánto se actualiza el directorio?",
    answer: "Revisamos el catálogo regularmente, añadimos descubrimientos útiles y retiramos productos cuya oferta gratuita deja de ser relevante.",
  },
  {
    question: "¿Por qué está disponible en dos idiomas?",
    answer: "Las buenas herramientas para developers deberían ser fáciles de descubrir tanto en inglés como en español.",
  },
] : [
  {
    question: "Are all these tools completely free?",
    answer: "Every product listed offers a useful free tier, but it may include usage, storage or team limits. It is not the same as an unlimited free product.",
  },
  {
    question: "Do I need a credit card?",
    answer: "Most resources do not require one. Every listing clearly identifies when a card is needed to unlock the complete free allowance.",
  },
  {
    question: "How often is the directory updated?",
    answer: "The catalog is reviewed regularly, adding useful discoveries and removing products whose free offer is no longer relevant.",
  },
  {
    question: "Why is the site available in two languages?",
    answer: "Great developer tools should be easy to discover in both English and Spanish.",
  },
]
const homeStructuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: "it's free*",
      alternateName: "itsfree.dev",
      url: siteUrl,
      description: homeDescription,
      inLanguage: locale,
      publisher: { "@type": "Organization", name: "midu.dev", url: "https://midu.dev" },
    },
    {
      "@type": "CollectionPage",
      "@id": `${siteUrl}${pagePath}#directory`,
      url: `${siteUrl}${pagePath}`,
      name: pageTitle,
      description: homeDescription,
      dateModified: sourceReviewedAt,
      isPartOf: { "@id": `${siteUrl}/#website` },
      mainEntity: {
        "@type": "ItemList",
        numberOfItems: pageResources.length,
        itemListElement: sortedResources.map((resource, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: resource.name,
          url: `${siteUrl}${localePrefix}/tools/${resource.slug}`,
        })),
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: faqEntries.map((entry) => ({
        "@type": "Question",
        name: entry.question,
        acceptedAnswer: { "@type": "Answer", text: entry.answer },
      })),
    },
  ],
}
---

<Layout
  title={pageTitle}
  description={homeDescription}
  locale={locale}
  canonical={pagePath}
  alternate={alternateUrl}
>
  <div class="site-shell">
    <header class="topbar" transition:name="site-header" transition:animate="none">
      <a class="brand" href={localePrefix || "/"} aria-label="it's free home">
        <LogoMark />
        <span class="brand-name">it's free<span>*</span></span>
      </a>

      <nav class="topbar-nav" aria-label="Primary navigation">
        <a href="#directory">{t({ en: "Explore", es: "Explorar" })}</a>
        <a href="#about">{t({ en: "About", es: "Sobre el proyecto" })}</a>
        <a href={`${localePrefix}/sponsor`}>{t({ en: "Sponsor", es: "Patrocinar" })}</a>
      </nav>

      <div class="topbar-actions">
        <button class="icon-button" id="theme-toggle" type="button" aria-label="Use light theme">
          <svg class="sun-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path></svg>
          <svg class="moon-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.4 15.5A8.4 8.4 0 0 1 8.5 3.6 8.4 8.4 0 1 0 20.4 15.5Z"></path></svg>
        </button>
        <a class="language-button" href={languageSwitchUrl} lang={locale === "es" ? "en" : "es"} rel="nofollow" aria-label={t({ en: "Cambiar a español", es: "Switch to English" })}>{locale === "es" ? "EN" : "ES"}</a>
      </div>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-glow" aria-hidden="true"></div>
        <p class="eyebrow"><span class="status-dot"></span><span>{t({ en: "The good part of the internet", es: "La parte buena de internet" })}</span></p>
        <h1 id="hero-title">
          <span>{selectedCategory ? t({ en: `Free ${selectedCategory.name.en}.`, es: `${selectedCategory.name.es} gratis.` }) : t({ en: "Build more.", es: "Construye más." })}</span>
          <span class="hero-accent">{selectedCategory ? t({ en: "Worth using.", es: "Que vale la pena." }) : t({ en: "Spend less.", es: "Gasta menos." })}</span>
        </h1>
        <p class="hero-copy">{selectedCategory ? homeDescription : t({ en: "A carefully selected catalog of products with genuinely useful free tiers for developers, makers and small teams.", es: "Un catálogo cuidadosamente seleccionado de productos con capas gratuitas realmente útiles para developers, makers y pequeños equipos." })}</p>

        <div class="hero-stats" aria-label="Directory statistics">
          <div><strong>{totalResources}</strong><span>{t({ en: "resources", es: "recursos" })}</span></div>
          <div><strong>{categories.length}</strong><span>{t({ en: "categories", es: "categorías" })}</span></div>
          <div><strong>{featuredResources}</strong><span>{t({ en: "editor's picks", es: "recomendados" })}</span></div>
          <div><strong>{reviewedDate}</strong><span>{t({ en: "last review", es: "última revisión" })}</span></div>
        </div>
      </section>

      <section class="directory" id="directory" aria-labelledby="directory-title" transition:name="directory" transition:animate="fade">
        <div class="directory-heading">
          <div>
            <p class="section-kicker">// DIRECTORY_01</p>
            <h2 id="directory-title">{selectedCategory ? pageTitle : t({ en: "Find your next tool", es: "Encuentra tu próxima herramienta" })}</h2>
          </div>
          <p>{t({ en: "Search by product, use case or technology.", es: "Busca por producto, caso de uso o tecnología." })}</p>
        </div>

        <div class="search-panel">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-4-4"></path></svg>
          <input
            id="search-input"
            type="search"
            autocomplete="off"
            spellcheck="false"
            placeholder={t({ en: `Search ${totalResources} free resources...`, es: `Busca entre ${totalResources} recursos gratis...` })}
            aria-label={t({ en: "Search resources", es: "Buscar recursos" })}
          />
          <kbd>/</kbd>
        </div>

        <div class="mobile-categories" aria-label="Resource categories">
          <a class:list={["mobile-category", { active: !selectedCategory }]} href={localePrefix || "/"} data-category-navigation>
            <CategoryIcon name="layout-grid" size={14} />
            <span>{t({ en: "All", es: "Todo" })}</span>
          </a>
          {categories.map((category) => (
            <a class:list={["mobile-category", { active: selectedCategory?.id === category.id }]} href={`${localePrefix}/categories/${category.id}`} data-category-navigation>
              <CategoryIcon name={category.icon} size={14} />
              <span>{t({ en: category.name.en, es: category.name.es })}</span>
            </a>
          ))}
        </div>

        <div class="catalog-layout">
          <aside class="category-sidebar">
            <div class="category-label">{t({ en: "Browse by category", es: "Explora por categoría" })}</div>
            <a class:list={["category-button", { active: !selectedCategory }]} href={localePrefix || "/"} data-category-navigation>
              <span class="category-icon"><CategoryIcon name="layout-grid" /></span>
              <span>{t({ en: "All resources", es: "Todos los recursos" })}</span>
              <small>{resources.length}</small>
            </a>
            {categories.map((category) => (
              <a class:list={["category-button", { active: selectedCategory?.id === category.id }]} href={`${localePrefix}/categories/${category.id}`} data-category-navigation>
                <span class="category-icon"><CategoryIcon name={category.icon} /></span>
                <span>{t({ en: category.name.en, es: category.name.es })}</span>
                <small>{categoryCounts.get(category.id)}</small>
              </a>
            ))}
            <a class="sponsor-mini" href={`${localePrefix}/sponsor`}>
              <span class="sponsor-mini-mark">AD*</span>
              <span>
                <strong>{t({ en: "Sponsor this directory", es: "Patrocina este directorio" })}</strong>
                <small>{t({ en: "€1,500 / 30 days →", es: "1.500 € / 30 días →" })}</small>
              </span>
            </a>
          </aside>

          <div class="results-column">
            <div class="results-toolbar">
              <p><span id="results-count">{totalResources}</span> <span>{t({ en: "resources found", es: "recursos encontrados" })}</span></p>
            </div>

            <div class="resource-grid" id="resource-grid">
              {sortedResources.map((resource) => {
                const category = categoryMap.get(resource.category)!
                const accessLabel = accessLabels[resource.accessRequirement]
                const freeTierEn = cleanFreeTierPrefix(resource.freeTier.en, "en")
                const freeTierEs = cleanFreeTierPrefix(resource.freeTier.es, "es")
                const initials = resource.name.split(/\s+/).map((word) => word[0]).join("").slice(0, 2).toUpperCase()
                const faviconUrl = getResourceFaviconUrl(resource)
                const searchable = [resource.name, resource.description[locale], resource.freeTier[locale], ...resource.tags, category.name[locale]].join(" ").toLowerCase()
                return (
                  <article class={`resource-card${resource.featured ? " is-featured" : ""}`} data-resource data-category={resource.category} data-name={resource.name} data-search={searchable}>
                    {resource.featured && <span class="featured-corner" title="Editor's pick">✦</span>}
                    <div class="card-topline">
                      <span class="resource-logo" aria-hidden="true">
                        <span class="resource-initials">{initials}</span>
                        <img src={faviconUrl} alt="" width="28" height="28" loading="lazy" decoding="async" referrerpolicy="no-referrer" />
                      </span>
                      <h3>{resource.name}</h3>
                      <a class="card-arrow card-external-link" href={resource.url} target="_blank" rel="noreferrer" aria-label={`Open ${resource.name} website`}>↗</a>
                    </div>
                    <div class="card-body">
                      <p>{t({ en: resource.description.en, es: resource.description.es })}</p>
                      <div class="free-tier">
                        <span
                          class:list={{
                            "is-trial": resource.accessRequirement === "trial-only",
                            "is-card-required": resource.accessRequirement === "card-for-full-limits",
                          }}
                        >{t({ en: accessLabel.en, es: accessLabel.es })}</span>
                        <p>{t({ en: freeTierEn, es: freeTierEs })}</p>
                      </div>
                    </div>
                    <div class="card-footer">
                      <div class="tags">{resource.tags.slice(0, 2).map((tag) => <span>{tag}</span>)}</div>
                    </div>
                    <a class="card-link" href={`${localePrefix}/tools/${resource.slug}`} aria-label={t({ en: `Read about ${resource.name}`, es: `Leer sobre ${resource.name}` })}></a>
                  </article>
                )
              })}
            </div>

            <div class="empty-state" id="empty-state" hidden>
              <span>Ø</span>
              <h3>{t({ en: "Nothing found in this corner.", es: "No hay nada por este rincón." })}</h3>
              <p>{t({ en: "Try another search or explore all categories.", es: "Prueba otra búsqueda o explora todas las categorías." })}</p>
              <button id="reset-filters" type="button">{t({ en: "Reset filters", es: "Limpiar filtros" })}</button>
            </div>
          </div>
        </div>
      </section>

      <section class="about-strip" id="about">
        <p class="section-kicker">// OPEN_WEB</p>
        <div>
          <h2>{t({ en: "Free should be easy to find.", es: "Lo gratis debería ser fácil de encontrar." })}</h2>
          <p>{t({ en: "An independent bilingual directory built to make genuinely useful free tools easier to discover. We review every entry and keep the catalog focused on products developers can actually use.", es: "Un directorio bilingüe e independiente creado para descubrir herramientas gratuitas realmente útiles. Revisamos cada entrada y mantenemos el catálogo centrado en productos que un developer puede usar de verdad." })}</p>
        </div>
        <a href="#directory"><span>{t({ en: "Explore the catalog", es: "Explorar el catálogo" })}</span><span>↓</span></a>
      </section>

      <section class="faq-section" id="faq" aria-labelledby="faq-title">
        <div class="faq-intro">
          <p class="section-kicker">// FAQ_04</p>
          <h2 id="faq-title">{t({ en: "Questions, answered.", es: "Preguntas, resueltas." })}</h2>
          <p>{t({ en: "The small print, without making it small.", es: "La letra pequeña, sin hacerla pequeña." })}</p>
        </div>

        <div class="faq-list">
          <details open>
            <summary><span>{t({ en: "Are all these tools completely free?", es: "¿Todas estas herramientas son completamente gratis?" })}</span><span class="faq-toggle">＋</span></summary>
            <p>{t({ en: "Every product listed offers a useful free tier, but it may include usage, storage or team limits. It is not the same as an unlimited free product.", es: "Todos los productos ofrecen una capa gratuita útil, aunque puede tener límites de uso, almacenamiento o equipo. No significa que sean productos gratuitos sin límites." })}</p>
          </details>
          <details>
            <summary><span>{t({ en: "How do you choose what gets listed?", es: "¿Cómo elegís qué aparece en el listado?" })}</span><span class="faq-toggle">＋</span></summary>
            <p>{t({ en: "We prioritize reliable tools with a free plan that is genuinely useful for building, learning or launching a real project.", es: "Priorizamos herramientas fiables con un plan gratuito que sea realmente útil para construir, aprender o lanzar un proyecto real." })}</p>
          </details>
          <details>
            <summary><span>{t({ en: "Can I use these services in production?", es: "¿Puedo usar estos servicios en producción?" })}</span><span class="faq-toggle">＋</span></summary>
            <p>{t({ en: "Often yes, especially for small apps. Check current limits, support, data location and upgrade costs with the provider before making a production decision.", es: "A menudo sí, especialmente en aplicaciones pequeñas. Comprueba límites, soporte, ubicación de datos y costes de ampliación antes de decidir." })}</p>
          </details>
          <details>
            <summary><span>{t({ en: "How often is the directory reviewed?", es: "¿Cada cuánto se revisa el directorio?" })}</span><span class="faq-toggle">＋</span></summary>
            <p>{t({ en: "We review the catalog regularly, add useful discoveries and remove products whose free offer is no longer relevant.", es: "Revisamos el catálogo regularmente, añadimos descubrimientos útiles y retiramos productos cuya oferta gratuita deja de ser relevante." })}</p>
          </details>
          <details>
            <summary><span>{t({ en: "Why is the site available in two languages?", es: "¿Por qué está disponible en dos idiomas?" })}</span><span class="faq-toggle">＋</span></summary>
            <p>{t({ en: "Great developer tools should be easy to discover in both English and Spanish. Each language has its own fast, indexable URL.", es: "Las buenas herramientas para developers deberían ser fáciles de descubrir en inglés y español. Cada idioma tiene su propia URL rápida e indexable." })}</p>
          </details>
        </div>
      </section>
    </main>

    <footer class="footer">
      <a class="brand footer-brand" href={localePrefix || "/"}><LogoMark /><span class="brand-name">it's free<span>*</span></span></a>
      <div class="footer-signature">
        <p><span>{t({ en: "A project by", es: "Un proyecto de" })}</span> <a href="https://midu.dev" target="_blank" rel="noreferrer">midu.dev ↗</a></p>
        <p>{t({ en: "Made for developers who read the pricing page first.", es: "Hecho para developers que leen primero la página de precios." })}</p>
      </div>
      <nav class="social-links" aria-label="midu.dev social networks">
        <a href="https://twitter.com/midudev" target="_blank" rel="noreferrer" aria-label="X / Twitter">X <span>↗</span></a>
        <a href="https://youtube.com/@midudev" target="_blank" rel="noreferrer" aria-label="YouTube">YouTube <span>↗</span></a>
        <a href="https://twitch.tv/midudev" target="_blank" rel="noreferrer" aria-label="Twitch">Twitch <span>↗</span></a>
        <a href="https://github.com/midudev/itsfree.dev" target="_blank" rel="noreferrer" aria-label={t({ en: "Open-source project on GitHub", es: "Proyecto de código abierto en GitHub" })}>{t({ en: "Open source", es: "Código abierto" })} <span>↗</span></a>
      </nav>
    </footer>
  </div>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(homeStructuredData)} />

  <script>
    const normalizeSearch = (value: string) => value
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, " ")
      .trim()
    const compactSearch = (value: string) => normalizeSearch(value).replace(/\s+/g, "")

    function initializeDirectoryPage() {
      const searchInput = document.querySelector<HTMLInputElement>("#search-input")
      const resultsCount = document.querySelector<HTMLElement>("#results-count")
      const emptyState = document.querySelector<HTMLElement>("#empty-state")
      if (!searchInput || !resultsCount || !emptyState || searchInput.dataset.enhanced === "true") return
      searchInput.dataset.enhanced = "true"

      const resourceCards = [...document.querySelectorAll<HTMLElement>("[data-resource]")]

      document.querySelectorAll<HTMLImageElement>(".resource-logo img").forEach((image) => {
        const useFallback = () => {
          image.parentElement?.classList.add("favicon-fallback")
          image.remove()
        }
        image.addEventListener("error", useFallback)
        if (image.complete && image.naturalWidth === 0) useFallback()
      })

      const applyFilters = () => {
        const query = normalizeSearch(searchInput.value)
        const compactQuery = compactSearch(searchInput.value)
        let visible = 0

        resourceCards.forEach((card) => {
          const searchable = normalizeSearch(card.dataset.search ?? "")
          const name = card.dataset.name ?? ""
          const matchesName = normalizeSearch(name).includes(query) || compactSearch(name).includes(compactQuery)
          const show = !query || matchesName || searchable.includes(query)
          card.hidden = !show
          if (show) visible += 1
        })

        resultsCount.textContent = String(visible)
        emptyState.hidden = visible !== 0
      }

      searchInput.addEventListener("input", applyFilters)
      document.querySelector("#reset-filters")?.addEventListener("click", () => {
        searchInput.value = ""
        applyFilters()
        searchInput.focus()
      })

      applyFilters()
    }

    document.addEventListener("keydown", (event) => {
      const searchInput = document.querySelector<HTMLInputElement>("#search-input")
      if (!searchInput) return
      if (event.key === "/" && document.activeElement !== searchInput) {
        event.preventDefault()
        searchInput.focus()
      }
      if (event.key === "Escape" && document.activeElement === searchInput) {
        searchInput.value = ""
        searchInput.dispatchEvent(new Event("input"))
        searchInput.blur()
      }
    })

    document.addEventListener("astro:page-load", initializeDirectoryPage)
    initializeDirectoryPage()
  </script>
</Layout>
